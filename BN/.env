PORT=5000

# MongoDB Connection (for cars data)
# Local: mongodb://127.0.0.1:27017/3d-login-db
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/3d-login-db?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/3d-login-db

# Supabase Auth
# Get these from your Supabase dashboard: Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (fallback if needed)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
